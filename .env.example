PORT=4000
NODE_ENV=development
APP_VERSION=12.0.0
CORS_ORIGIN=*

# Leave DATABASE_URL blank for local JSON fallback during development.
DATABASE_URL=
PGSSL=false
ALLOW_LOCAL_FALLBACK=true
DISABLE_LOCAL_AUTH=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=exports
STORAGE_BUCKET=resumes

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

REDIS_URL=
ENABLE_QUEUE_WORKER=false
RESEND_API_KEY=
EMAIL_FROM=JobNova <noreply@example.com>
UPLOAD_MAX_SIZE_MB=10

EXPORT_TEST_THEME=classic-canadian-professional
EXPORT_TEST_LAYOUT=one-page

PG_CONNECT_TIMEOUT_MS=3000
PG_IDLE_TIMEOUT_MS=10000
PG_POOL_MAX=10

GOOGLE_APPLICATION_CREDENTIALS_JSON=

PUPPETEER_SKIP_DOWNLOAD=true
# Optional: set this only if you want puppeteer-core to use a local Chrome install
# PUPPETEER_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
