EXPO_PUBLIC_APP_NAME=JobNova
EXPO_PUBLIC_APP_VERSION=11.2.0
EXPO_PUBLIC_PROJECT_SLUG=jobnova
EXPO_PUBLIC_BUNDLE_ID=com.jobnova.app
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_USE_MOCK_API=false
EXPO_PUBLIC_API_BASE_URL=http://YOUR_COMPUTER_IP:4000

EXPO_PUBLIC_SUBSCRIPTION_PROVIDER=apple-direct
EXPO_PUBLIC_SUBSCRIPTION_GROUP_NAME=JobNova Pro
EXPO_PUBLIC_APPLE_WEEKLY_PRODUCT_ID=JobNova.weekly.pro
EXPO_PUBLIC_APPLE_MONTHLY_PRODUCT_ID=JobNova.monthly.pro
EXPO_PUBLIC_APPLE_ANNUAL_PRODUCT_ID=JobNova.annual.pro
EXPO_PUBLIC_SUBSCRIPTION_MANAGE_URL=

# V13 final hardening
STRICT_PERSISTENCE=true
OCR_ENABLED=true
OCR_LANGUAGES=eng
JOB_BROWSER_EXTRACTION_ENABLED=true
JOB_EXTRACTION_LOCALE=en-US,en;q=0.9
PUPPETEER_EXECUTABLE_PATH=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=30
UPLOAD_RATE_LIMIT_MAX=20
