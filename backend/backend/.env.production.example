# JobNova backend production environment
PORT=4000
NODE_ENV=production
APP_VERSION=12.0.0
CORS_ORIGIN=*

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=exports
STORAGE_BUCKET=resumes

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
PGSSL=true

ENABLE_QUEUE_WORKER=false
REDIS_URL=redis://red-xxxxxxxxxxxxxxxx:6379

RESEND_API_KEY=re_...
EMAIL_FROM=JobNova <noreply@yourdomain.com>

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
GREENHOUSE_BOARD_TOKENS=
LEVER_COMPANIES=

UPLOAD_MAX_SIZE_MB=10
JWT_SECRET=replace_with_a_long_random_string_32_plus_chars
JWT_EXPIRES_IN=7d

ALLOW_LOCAL_FALLBACK=true
DISABLE_LOCAL_AUTH=true

EXPORT_TEST_THEME=classic-canadian-professional
EXPORT_TEST_LAYOUT=one-page

PG_CONNECT_TIMEOUT_MS=3000
PG_IDLE_TIMEOUT_MS=10000
PG_POOL_MAX=10
