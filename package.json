{
  "name": "jobnova-backend",
  "version": "19.0.0",
  "private": true,
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": "20.18.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "preflight": "node -e \"const cfg=require('./config/env'); cfg.assertProductionReadiness(); console.log('Backend env OK')\"",
    "worker": "ENABLE_QUEUE_WORKER=true node workers/queueWorker.js"
  },
  "dependencies": {
    "@google-cloud/vision": "^4.3.0",
    "@sentry/node": "^10.22.0",
    "@supabase/supabase-js": "^2.56.0",
    "archiver": "^7.0.1",
    "body-parser": "^2.2.2",
    "bullmq": "^5.16.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.6",
    "docx": "^9.5.1",
    "dotenv": "^16.6.1",
    "expo-audio": "~1.1.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.8.0",
    "multer": "^2.1.1",
    "openai": "^5.23.2",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.13.1",
    "puppeteer": "^24.6.0",
    "resend": "^4.7.0",
    "tesseract.js": "^6.0.1",
    "uuid": "^11.0.3",
    "zod": "^3.24.2"
